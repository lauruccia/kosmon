APP_NAME=KMoney
# ATTENZIONE: in PRODUZIONE impostare SEMPRE APP_ENV=production e APP_DEBUG=false.
# Lasciare APP_DEBUG=true in produzione espone stack trace e configurazione sensibile.
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Proxy fidati per gli header X-Forwarded-* (IP reale del client).
# NON usare "*" in produzione: rende X-Forwarded-For falsificabile e
# compromette rate limiting, anti-frode su IP e notifiche "nuovo IP".
# Lasciare vuoto = default sicuro (loopback + reti private), adatto a
# cPanel/LiteSpeed dove PHP gira dietro il web server locale.
# Se in futuro si mette un CDN davanti (es. Cloudflare), elencare qui i
# suoi range CSV: TRUSTED_PROXIES="173.245.48.0/20,103.21.244.0/22,..."
TRUSTED_PROXIES=

APP_LOCALE=it
APP_FALLBACK_LOCALE=it
APP_FAKER_LOCALE=it_IT

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
HEALTH_CHECK_TOKEN=

# ── Database ──────────────────────────────────────────────────────────────────
# Sviluppo locale: SQLite
DB_CONNECTION=sqlite

# Produzione: MySQL (decommenta e configura)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=kmoney
# DB_USERNAME=kmoney_user
# DB_PASSWORD=password_sicura

# ── Session / Cache / Queue ───────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Produzione: usa redis per session, cache e queue
# SESSION_DRIVER=redis
# CACHE_STORE=redis
# QUEUE_CONNECTION=redis
# QUEUE_FAILED_DRIVER=database-uuids  # o redis

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ── Redis (produzione) ────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# Database separati per evitare collisioni di chiavi tra cache/session/queue
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2

# ── Mail ──────────────────────────────────────────────────────────────────────
# Sviluppo locale: log (tutte le email finiscono in storage/logs/laravel.log)
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@kmoney.it"
MAIL_FROM_NAME="KMoney"

# Produzione con Resend (https://resend.com — piano free 3.000 email/mese)
# MAIL_MAILER=resend
# RESEND_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Produzione con Mailgun
# MAIL_MAILER=mailgun
# MAILGUN_DOMAIN=mg.tuodominio.it
# MAILGUN_SECRET=key-xxxxxxxxxxxxxxxxxxxx
# MAILGUN_ENDPOINT=api.eu.mailgun.net

# Produzione con SMTP generico
# MAIL_MAILER=smtp
# MAIL_SCHEME=tls
# MAIL_HOST=smtp.tuoprovider.it
# MAIL_PORT=587
# MAIL_USERNAME=noreply@kmoney.it
# MAIL_PASSWORD=password_smtp

# ── Storage S3 (documenti KYC in produzione) ─────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-south-1
AWS_BUCKET=kmoney-docs
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Vite ──────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"

# Web Push (VAPID) — genera le chiavi con: php artisan webpush:vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@kmoney.it

# ── Broadcasting / WebSocket real-time ───────────────────────────────────────
# Opzione A: Laravel Reverb (self-hosted, raccomandato)
# Installa con: composer require laravel/reverb && php artisan reverb:install
# Avvia con: php artisan reverb:start
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=kmoney-app
REVERB_APP_KEY=kmoney-key-local
REVERB_APP_SECRET=kmoney-secret-local
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# Variabili Vite per il frontend Echo
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Opzione B: Pusher (managed) — decommenta e compila se preferisci Pusher
# BROADCAST_CONNECTION=pusher
# PUSHER_APP_ID=
# PUSHER_APP_KEY=
# PUSHER_APP_SECRET=
# PUSHER_APP_CLUSTER=eu
# VITE_PUSHER_APP_